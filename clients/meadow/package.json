{
  "name": "meadow",
  "version": "2.0.0-dev",
  "description": "Modern web client for mooR - a 21st century LambdaMOO implementation",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "VITE_WEBHOOKS_ENABLED=true vite",
    "build": "tsc && vite build",
    "build:deb": "npm run build && ./deploy/debian-packages/build-web-client-deb.sh",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "moor:dev": "cd ${MOOR_PATH:-../..} && npm run moor:dev",
    "moor:dev:oauth2": "cd ${MOOR_PATH:-../..} && npm run moor:dev:oauth2",
    "full:dev": "concurrently \"npm run dev\" \"npm run moor:dev\"",
    "full:dev:oauth2": "concurrently \"npm run dev\" \"npm run moor:dev:oauth2\""
  },
  "keywords": [
    "moo",
    "lambdamoo",
    "typescript",
    "web-client",
    "mud-client",
    "moo-client"
  ],
  "author": "Ryan Daum <ryan.daum@gmail.com>",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://codeberg.org/timbran/meadow.git"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@guidepup/virtual-screen-reader": "^0.32.1",
    "@tauri-apps/cli": "^2.9.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.1",
    "@types/prismjs": "^1.26.4",
    "@types/react": "^18.3.27",
    "@types/react-avatar-editor": "^13.0.4",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.35.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.4.0",
    "jsdom": "^27.4.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "^4.0.17"
  },
  "dependencies": {
    "@djot/djot": "^0.3.2",
    "@monaco-editor/react": "^4.7.0",
    "@moor/schema": "2.0.0-dev.20260409140240616926485.3381075.580e0ad1",
    "@moor/web-sdk": "2.0.0-dev.20260409142513981793216.3381330.719e406f",
    "@tauri-apps/api": "^2.9.1",
    "age-encryption": "^0.2.4",
    "ansi_up": "^6.0.6",
    "argon2-browser": "^1.18.0",
    "dompurify": "^3.2.6",
    "flatbuffers": "^25.9.23",
    "monaco-editor": "^0.55.1",
    "prismjs": "^1.30.0",
    "react": "^18.3.1",
    "react-avatar-editor": "^13.0.2",
    "react-dom": "^18.3.1"
  }
}
