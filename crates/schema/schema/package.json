{
  "name": "@moor/schema",
  "version": "2.0.0-dev",
  "private": true,
  "description": "FlatBuffer schemas and TypeScript bindings for mooR",
  "type": "module",
  "main": "./dist/generated/all_schemas.js",
  "types": "./dist/generated/all_schemas.d.ts",
  "exports": {
    "./generated/*": {
      "types": "./dist/generated/*.d.ts",
      "import": "./dist/generated/*.js",
      "default": "./dist/generated/*.js"
    },
    "./*.fbs": "./*.fbs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/timbran-project/moor.git",
    "directory": "crates/schema/schema"
  },
  "license": "LGPL-3.0-or-later",
  "files": [
    "dist",
    "*.fbs",
    "LICENSE"
  ],
  "scripts": {
    "generate": "rm -rf generated && mkdir -p generated && flatc --ts --gen-all -o generated all_schemas.fbs",
    "build": "npm run generate && rm -rf dist && tsc -p tsconfig.json"
  },
  "dependencies": {
    "flatbuffers": "^25.9.23"
  },
  "devDependencies": {
    "typescript": "^5.9.2"
  }
}
