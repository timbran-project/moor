#!/bin/sh
set -e

MOOR_USER="moor"
DATABASE_DIR="/var/spool/moor"
LIB_DIR="/var/lib/moor"
CONFIG_DIR="/etc/moor"
MOOR_HOME=${DATABASE_DIR}

create_user() {
  if id ${MOOR_USER} > /dev/null 2>&1; then return; fi
  adduser --system --home "${MOOR_HOME}" --group ${MOOR_USER}
}

create_directories() {
  mkdir -p ${DATABASE_DIR}
  mkdir -p ${LIB_DIR}
  mkdir -p ${CONFIG_DIR}
  chown -R ${MOOR_USER}:${MOOR_USER} ${LIB_DIR}
  chown -R ${MOOR_USER}:${MOOR_USER} ${DATABASE_DIR}
  chown -R ${MOOR_USER}:${MOOR_USER} ${CONFIG_DIR}
  chmod 700 ${CONFIG_DIR}

  echo ""
  echo "** The moor package includes a LambdaCore-based core (with modifications for moor)"
  echo "** at /usr/share/moor/cores/lambda-moor/src - see README.md in that directory for details."
  echo "** This core will be used by default. To use a different core, update"
  echo "** /etc/moor/moor-config.yaml (import_export.input_path) and restart with 'systemctl restart moor'."
  echo ""
}

generate_keys() {
  if [ ! -f ${CONFIG_DIR}/moor-signing-key.pem ] || [ ! -f ${CONFIG_DIR}/moor-verifying-key.pem ]; then
    echo "** Generating PASETO signing and verifying keys for client authentication."
    openssl genpkey -algorithm ed25519 -out ${CONFIG_DIR}/moor-signing-key.pem
    openssl pkey -in ${CONFIG_DIR}/moor-signing-key.pem -pubout -out ${CONFIG_DIR}/moor-verifying-key.pem

    chown ${MOOR_USER}:${MOOR_USER} ${CONFIG_DIR}/moor-signing-key.pem
    chown ${MOOR_USER}:${MOOR_USER} ${CONFIG_DIR}/moor-verifying-key.pem
    chmod 600 ${CONFIG_DIR}/moor-signing-key.pem ${CONFIG_DIR}/moor-verifying-key.pem
  else
    echo "** PASETO keys already exist at ${CONFIG_DIR}/moor-*-key.pem, skipping generation."
  fi
}

generate_enrollment_token() {
  if [ ! -f ${CONFIG_DIR}/enrollment-token ]; then
    echo "** Generating enrollment token."
    if command -v uuidgen >/dev/null 2>&1; then
      uuidgen > ${CONFIG_DIR}/enrollment-token
    else
      cat /proc/sys/kernel/random/uuid > ${CONFIG_DIR}/enrollment-token
    fi
    chown ${MOOR_USER}:${MOOR_USER} ${CONFIG_DIR}/enrollment-token
    chmod 600 ${CONFIG_DIR}/enrollment-token
  fi
}

case "$1" in
configure)
    create_user
    create_directories
    generate_keys
    generate_enrollment_token
    ;;
esac

deb-systemd-helper unmask moor.service > /dev/null || true

if deb-systemd-helper --quiet was-enabled moor.service
then
	deb-systemd-helper enable moor.service > /dev/null || true
	deb-systemd-invoke start moor
else
	deb-systemd-helper update-state moor.service > /dev/null || true
fi

#DEBHELPER#
